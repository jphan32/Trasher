# trash-classifier 환경설정 예시.

# GCP 서비스 계정 JSON 키 경로(필수). 절대 커밋 금지(secret/는 gitignore됨).
CLASSIFIER_CREDENTIALS=secret/gemini-api-key.json

# Gemini 모델 id
CLASSIFIER_MODEL=gemini-3.5-flash

# 바인드 주소/포트
CLASSIFIER_HOST=0.0.0.0
CLASSIFIER_PORT=8090

# Gemini 호출 타임아웃(초) / 온도
CLASSIFIER_TIMEOUT=60
CLASSIFIER_TEMPERATURE=0
