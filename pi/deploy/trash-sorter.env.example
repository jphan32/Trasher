# /etc/trash-sorter.env — 현장 튜닝값(전부 선택, 없으면 config.py 기본값).
# 설치: sudo cp trash-sorter.env.example /etc/trash-sorter.env 후 편집.

# --- 네트워크 ---
# 광고할 IP(빈 값이면 자동 감지). 고정 IP/DHCP 예약 시 명시 권장.
#TRASH_ADVERTISED_IP=192.168.0.50
#TRASH_HTTP_PORT=8080
#TRASH_DEVICE_NAME=sorter-01
#TRASH_PHOTO_RETENTION=20
# 사진 저장 디렉터리(고정/시드용). 미설정 시 자동(mock=임시 / 실기기=/var/tmp/trash-photos).
#TRASH_PHOTO_DIR=/var/tmp/trash-photos

# --- 서보 GPIO 핀(BCM) — docs/hardware.md 핀맵과 일치시킬 것 ---
#TRASH_GATE_PIN=17
#TRASH_LEFT_PIN=27
#TRASH_RIGHT_PIN=22
# 서보(SER0043 연속회전): 저속 구동+시간으로 하드스톱까지 이동 후 정지(detach). docs/hardware.md.
#TRASH_SERVO_SPEED=0.3      # 저속 세기 0..1(낮을수록 느림)
#TRASH_SERVO_TRAVEL=0.8     # 한 스톱→반대 스톱 이동 시간(초)
#TRASH_GATE_DIR=1           # open(방출/분기 열림) 방향 부호(+1/-1). close는 반대
#TRASH_LEFT_DIR=1
#TRASH_RIGHT_DIR=1

# --- 벨트 모터 ---
# 분류 이동 시간(초) — §2.5 T_belt
#TRASH_BELT_SECONDS=3.0
# 드라이버 선택: gpiozero(GPIO+L298N류, 기본) | hiwonder(I2C 4ch SA8339/SA8870C). docs/hardware.md.
#TRASH_BELT_DRIVER=gpiozero
# (A) gpiozero 드라이버 핀(BCM)
#TRASH_BELT_FWD_PIN=23
#TRASH_BELT_BWD_PIN=24
# (B) Hiwonder I2C 드라이버 — 선결: I2C 활성화 + i2cdetect로 주소 확인
#TRASH_BELT_I2C_BUS=1
#TRASH_BELT_I2C_ADDR=0x34
#TRASH_BELT_PWM=60          # 개루프 세기 0..100
#TRASH_BELT_CH_A=0          # 보드 채널 인덱스(0..3)
#TRASH_BELT_CH_B=1
#TRASH_BELT_INVERT_A=false  # 미러 2모터 → 한쪽 부호 반전(기본 B만 반전)
#TRASH_BELT_INVERT_B=true

# --- 비전(변이검출) — `trash-sorter --tune <dir>`로 보정 ---
#TRASH_CAM_W=1280
#TRASH_CAM_H=720
#TRASH_JPEG_Q=80
#TRASH_MOTION_THRESH=0.02
#TRASH_SETTLE_SEC=0.5

# --- 타이밍 ---
#TRASH_RESULT_TIMEOUT=15.0
#TRASH_HEARTBEAT=2.0

# 강제 Mock(하드웨어 없이 실행 시): 1=mock, 0=실기기
#TRASH_MOCK=0

# --- Gemini 분류(/classify 엔드포인트) ---
# SA 키 경로(없으면 Mock 분류기로 동작). secret/는 gitignore. 키에 결제/쿼터 필요.
#TRASH_GEMINI_CREDENTIALS=/opt/trash-sorter/secret/gemini-api-key.json
#TRASH_GEMINI_MODEL=gemini-3.5-flash
#TRASH_GEMINI_TIMEOUT=60

# --- 서보 PWM 안정화 ---
# pigpio 데몬(sudo systemctl enable --now pigpiod) 사용 시 지터 감소. docs/pi-setup.md §6.
#GPIOZERO_PIN_FACTORY=pigpio
